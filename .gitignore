# ===========================================================================
# dmstudio .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python bytecode & cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------------------------------------------------------------
# Python packaging & distribution artifacts
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
*.manifest
*.spec
MANIFEST
.installed.cfg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Jupyter Notebook
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.cache
.hypothesis/
nosetests.xml

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
local_settings.py

# ---------------------------------------------------------------------------
# Editor & IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace
.spyderproject
.spyproject
.ropeproject

# ---------------------------------------------------------------------------
# OS artifacts
# ---------------------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# dmstudio — Runtime-generated files
# (created fresh each session by initialize._make_dmdir())
# ---------------------------------------------------------------------------
dmdir.py
__init__.py

# ---------------------------------------------------------------------------
# dmstudio — Datamine Studio RM project & binary data files
# These are large, machine-specific, or generated by Studio at runtime.
# The tutorial .dmx files (_vb_*.dmx) are excluded because:
#   - They are Datamine binary files readable only with a Studio license
#   - They can be recreated from the Datamine help documentation
# ---------------------------------------------------------------------------
*.rmproj
*.dat
*.dmx
*.dm
*.key

# ---------------------------------------------------------------------------
# dmstudio — datamine help/ folder
# This is a local export of the StudioRM.chm help file (hundreds of MB).
# It is only needed when regenerating dmcommands.py via generate_wrappers.py.
# The generated output (dmcommands.py, dmfiles.py) IS committed to the repo.
# ---------------------------------------------------------------------------
datamine help/

# ---------------------------------------------------------------------------
# dmstudio — Datamine Studio project database (auto-managed by Studio RM)
# ---------------------------------------------------------------------------
Database/

# ---------------------------------------------------------------------------
# dmstudio — temporary test notebook outputs
# ---------------------------------------------------------------------------
tests/test_generated_workflow.ipynb

# ---------------------------------------------------------------------------
# mkdocs / documentation build
# ---------------------------------------------------------------------------
/site
docs/_build/

# ---------------------------------------------------------------------------
# Translations
# ---------------------------------------------------------------------------
*.mo
*.pot

# ---------------------------------------------------------------------------
# celery / other tooling
# ---------------------------------------------------------------------------
celerybeat-schedule
*.sage.py
