# ===========================================================================
# dmstudio .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python bytecode & cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------------------------------------------------------------
# Python packaging & distribution artifacts
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
*.manifest
*.spec
MANIFEST
.installed.cfg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Jupyter Notebook
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.cache
.hypothesis/
nosetests.xml

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
local_settings.py

# ---------------------------------------------------------------------------
# Editor & IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace
.spyderproject
.spyproject
.ropeproject

# ---------------------------------------------------------------------------
# OS artifacts
# ---------------------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# dmstudio — Runtime-generated files
# (created fresh each session by initialize._make_dmdir())
# ---------------------------------------------------------------------------
dmdir.py
__init__.py

# ---------------------------------------------------------------------------
# dmstudio — Datamine Studio RM project & binary data files
# These are large, machine-specific, or generated by Studio at runtime.
# The tutorial .dmx files (_vb_*.dmx) are excluded because:
#   - They are Datamine binary files readable only with a Studio license
#   - They can be recreated from the Datamine help documentation
# ---------------------------------------------------------------------------
*.rmproj
*.dat
*.dmx
*.dm
*.key

# Ignore session-specific Datamine project metadata
*.rmproj.spf
*.rmproj.cmf
*.rmproj.sfm

# ---------------------------------------------------------------------------
# dmstudio — datamine help/ folder
# This is a local export of the StudioRM.chm help file (hundreds of MB).
# It is only needed when regenerating dmcommands.py via generate_wrappers.py.
# The generated output (dmcommands.py, dmfiles.py) IS committed to the repo.
# ---------------------------------------------------------------------------
datamine_help/

# ---------------------------------------------------------------------------
# dmstudio — Datamine Studio project database (auto-managed by Studio RM)
# ---------------------------------------------------------------------------
/Database/

# ---------------------------------------------------------------------------
# Allow committing tutorial database files
# ---------------------------------------------------------------------------
!/tutorials/Database/
!/tutorials/Database/**

# ---------------------------------------------------------------------------
# dmstudio — temporary test notebook outputs
# ---------------------------------------------------------------------------
tests/test_generated_workflow.ipynb

# ---------------------------------------------------------------------------
# mkdocs / documentation build
# ---------------------------------------------------------------------------
/site
docs/_build/

# ---------------------------------------------------------------------------
# Translations
# ---------------------------------------------------------------------------
*.mo
*.pot

# ---------------------------------------------------------------------------
# celery / other tooling
# ---------------------------------------------------------------------------
celerybeat-schedule
*.sage.py

# ---------------------------------------------------------------------------
# AI Agent Workspaces
# ---------------------------------------------------------------------------
.agents/
!.agents/skills/
!.agents/skills/**

# ---------------------------------------------------------------------------
# dmstudio - Public Publishing Exceptions
# ---------------------------------------------------------------------------
# Exclude core package init from being ignored
!/dmstudio/__init__.py

# Allow committing tutorial/case-study files
!/tutorials/**/*.rmproj
!/tutorials/**/*.dm
!/tutorials/**/*.dmx
!/tutorials/**/*.dat

# Exclude local developer scratchpads and session files
promptlist
**/dmstusub.dat

# ---------------------------------------------------------------------------
# dmstudio — Test runner sandbox & results
# ---------------------------------------------------------------------------
# Ignore all runtime files and metadata generated inside the test sandbox
/tutorials/test_sandbox/*
!/tutorials/test_sandbox/Project.rmproj

# Ignore all generated test execution results
/tutorials/test_results/
