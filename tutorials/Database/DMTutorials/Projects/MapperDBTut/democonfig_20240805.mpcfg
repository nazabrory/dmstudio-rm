	<MapTypes>

		<MapType>
			<Name>Face</Name>
			<Sides>FRONT</Sides>
			<ReportTemplate>TemplateFace4.dmtpl</ReportTemplate>			
		</MapType>

		<MapType>
			<Name>Heading</Name>
			<Sides>FRONT,LEFT,RIGHT,TOP</Sides>
			<ReportTemplate>Template8.dmtpl</ReportTemplate>		
		</MapType>

		<MapType>
			<Name>Panel</Name>
			<Sides>FRONT</Sides>
			<ReportTemplate>PanelTemplate8.dmtpl</ReportTemplate>	
			<UseAutomaticOverlayMode>TRUE</UseAutomaticOverlayMode>	
		</MapType>

		<MapType>
			<Name>Location</Name>
			<Sides>TOP</Sides>
			<ReportTemplate>LocationTemplate.dmtpl</ReportTemplate>		
		</MapType>

	</MapTypes>

	<LevelMapTypes>

			<LevelMapType>
				<Name>LEVEL1-500</Name>
				<ReportTemplate>Level.dmtpl</ReportTemplate>
				<MapGridFormat>
					<Origin>centre</Origin>
					<Template>DemoGrid</Template>
				</MapGridFormat>
			</LevelMapType>

			<LevelMapType>
				<Name>LEVEL1-1000</Name>
				<ReportTemplate>Level.dmtpl</ReportTemplate>
				<MapGridFormat>
					<Origin>centre</Origin>
					<Template>DemoGrid</Template>
				</MapGridFormat>
			</LevelMapType>

	</LevelMapTypes>

	<ChannelSampleStandards>
		<Standard><Name>QTZ FLUSH</Name></Standard>
		<Standard><Name>BLANK</Name></Standard>
		<Standard><Name>LG1</Name></Standard>
		<Standard><Name>MG2</Name></Standard>
		<Standard><Name>PLG</Name></Standard>
		<Standard><Name>PMG</Name></Standard>
		<Standard><Name>PVH</Name></Standard>
	</ChannelSampleStandards>

	<NamingConventions>
	
		<Map>
			<BaseString>Map{0}-{1}</BaseString>
			<Parameter key="0">DATE_YYYYMMDD</Parameter>
			<Parameter key="1">ID</Parameter>
		</Map>

		<SampleID>
			<BaseString>Sample{0}</BaseString>
			<Parameter key="0">ID</Parameter>
		</SampleID>

        <ChannelSamples>
			<MinDigits>4</MinDigits>
		</ChannelSamples>

	</NamingConventions>

	<MapGridFormat>
    	<Template>GridTemplate</Template>
	</MapGridFormat>

<ButterflySettings enabled="true" outlinestolerance='0.5'/> 

</MappingConfiguration>