!REM

!rem -------------------------------------------------------------------
!rem  Define initial default values for substitution variables.  These 
!rem  will only be used the first time the macro is run.  On subsequent 
!rem  runs they will be overwritten by values from the var file.
!rem -------------------------------------------------------------------
!let $E# = 0
!let $N# = 0
!let $Z# = 0
!let $AZIM# = 0
!let $APPEND# = 0 


!rem -------------------------------------------------------------------
!rem  Test if the var file exists, and if so retrieve values.
!rem -------------------------------------------------------------------
!SYSFILE $EXISTS#=Shovel.var
!if $EXISTS#=1, then
  !VARLOAD Shovel.var,@MERGE=1
!endif

!PROMPT
0
1 Append Shovels (0=no, 1=yes)    [$APPEND#] ? '$APPEND#',N
1 position of shovel in Easting   [$E#] ? '$E#',N
1 position of shovel in Northing  [$N#] ? '$N#',N
1 position of shovel in Elevation [$Z#] ? '$Z#',N
1 Azimuth that shovel is facing   [$AZIM#] ? '$AZIM#',N

!CDTRAN &IN(SHOVELPT),&OUT(T1),*X(XP),*Y(YP),*Z(ZP),*NEWX(XP),
        *NEWY(YP),*NEWZ(ZP),@ANGLE1=-$AZIM#,@ANGLE2=0.0,@ANGLE3=0.0,
        @ROTAXIS1=3.0,@ROTAXIS2=1.0,@ROTAXIS3=3.0,@X0=0.0,
        @Y0=0.0,@Z0=0.0,@XR0=$E#,@YR0=$N#,@ZR0=$Z#,
        @FACTOR=1.0,@INVERSE=0.0,@PRINT=0.0,@ECHO=0.0
!COPY &IN(SHOVELTR),&OUT(T2)

!rem --------------------------------------------------------------------------
!rem  Catch the situation where the user wants to append to a non-existing file
!rem --------------------------------------------------------------------------
!SYSFILE $EXISTS#=shovtr.dm
!if $EXISTS#=0, then
  !if $APPEND#=1, then
    !let $APPEND# = 0
  !ENDIF
!ENDIF 

!IF $APPEND#=0, THEN
   !COPY &IN(T1),&OUT(SHOVPT)
   !COPY &IN(T2),&OUT(SHOVTR)
!ELSE
   !ADDTRI &WIREPT1(SHOVPT),&WIRETR1(SHOVTR),
           &WIREPT2(T1),&WIRETR2(T2),
           &WIREPTOU(SHOVPT),&WIRETROU(SHOVTR)
!ENDIF

!del &in(shovelpt)
!del &in(shoveltr)
!VARSAVE shovel.var
!END